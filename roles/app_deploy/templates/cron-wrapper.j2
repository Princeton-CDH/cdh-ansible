#!/bin/bash
# Generated by Ansible

export PATH=/usr/local/bin:/usr/bin:/bin

APP_CONFIG="$HOME/app_configs/{{ app_name }}"

if [ -f "$APP_CONFIG" ]; then
    set -a # automatically export all variables
    source "$APP_CONFIG"
    set +a
else
    echo "$(date): ERROR - Configuration file $APP_CONFIG not found."
    exit 1
fi

echo "------------------------------------------------------------"
echo "TIME: $(date)"
echo "EXEC: $@"
echo "------------------------------------------------------------"

# Using 'exec' replaces the shell process with the command process
exec "$@"
